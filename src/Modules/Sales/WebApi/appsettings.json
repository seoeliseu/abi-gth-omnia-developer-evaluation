{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observabilidade": {
    "SeqUrl": "http://localhost:5341"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=developer_evaluation;Username=postgres;Password=postgres",
    "MongoDb": "mongodb://localhost:27017/developer-evaluation"
  },
  "RabbitMq": {
    "ConnectionString": "amqp://guest:guest@localhost:5672",
    "QueueName": "developer-evaluation.sales.webapi"
  },
  "AllowedHosts": "*"
}