# Copie este arquivo para .env e ajuste conforme o ambiente.

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DEFAULT_DB=developer_evaluation_sales
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

JWT_ISSUER=Ambev.DeveloperEvaluation
JWT_AUDIENCE=Ambev.DeveloperEvaluation.Clients
JWT_SECRET_KEY=change-this-jwt-secret-with-at-least-32-bytes
JWT_EXPIRATION_MINUTES=60
HTTPS_REDIRECTION_ENABLED=false
DATA_PROTECTION_CERT_PASSWORD=local-dev-data-protection

MONGODB_HOST=mongodb
MONGODB_PORT=27017

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MAX_DELIVERY_ATTEMPTS=5

SEQ_HOST=seq
SEQ_PORT=5341